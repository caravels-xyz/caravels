# ── TWAK (Trust Wallet Agent Kit) ─────────────────────────────────────────────
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
# Full path to twak binary — required when nvm manages Node and the binary is
# not on the default PATH used by subprocess (no shell rc loaded).
# Find yours with: which twak   (after nvm use default)
TWAK_BIN=twak

# ── Strategy settings ──────────────────────────────────────────────────────────
# Path to the settings JSON file (risk limits, token universe, strategy params).
# Default: settings.json in the repo root. Override for different profiles.
# Example: CARAVELS_SETTINGS=/path/to/settings.competition.json
CARAVELS_SETTINGS=

# ── CoinMarketCap Agent Hub ────────────────────────────────────────────────────
CMC_API_KEY=

# ── BNB Agent SDK ─────────────────────────────────────────────────────────────
WALLET_PASSWORD=
PRIVATE_KEY=               # first run only — encrypted to ~/.bnbagent/wallets/ then removable
NETWORK=bsc-mainnet        # bsc-testnet for development

# ── LLM provider (pick one or set CARAVELS_LLM_PROVIDER below) ────────────────
MISTRAL_API_KEY=
OPENAI_API_KEY=

# ── Caravels runtime ──────────────────────────────────────────────────────────
CARAVELS_LLM_PROVIDER=mistral           # mistral | openai
CARAVELS_DRY_RUN=true                   # true = paper mode, no real trades
CARAVELS_COMPETITION_MODE=false         # true = enforce daily quota + drawdown gate + registration check
CARAVELS_SIMULATION_MODE=false          # true = all competition rules EXCEPT registration (safe for pre-registration paper runs)
CARAVELS_EMERGENCY_PAUSE=false          # true = halt all execution
CARAVELS_LADDER_ENABLED=true            # true = use grid-informed laddered orders
CARAVELS_X402_ENRICH=false              # true = enable optional paid CMC x402 enrichment via twak x402
CARAVELS_X402_PROVIDER=agentdata        # agentdata | cmc
CARAVELS_AGENTDATA_BASE_URL=https://agentdata-api.com
CARAVELS_AGENTDATA_SENTIMENT_PATH=/api/sentiment
CARAVELS_LOG_LEVEL=INFO
CARAVELS_LOOP_INTERVAL_SECONDS=60       # seconds to wait between iterations (calls to TWAK for new signals) overrides everything

# ── Paths ─────────────────────────────────────────────────────────────────────
# Leave blank to use the default path: <package_dir>/caravels.db
CARAVELS_DB_PATH=
